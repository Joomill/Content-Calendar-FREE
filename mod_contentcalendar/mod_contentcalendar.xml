<?xml version="1.0" encoding="utf-8"?>
<extension type="module" version="5.0" client="administrator" method="upgrade">
    <name>MOD_CONTENTCALENDAR</name>
    <description>MOD_CONTENTCALENDAR_XML_DESCRIPTION</description>
    <author>Jeroen Moolenschot | Joomill</author>
    <authorEmail>info@joomill-extensions.com</authorEmail>
    <authorUrl>https://www.joomill-extensions.com</authorUrl>
    <license>GNU General Public License version 3 or later</license>
    <creationDate>June 2026</creationDate>
    <copyright>(C) 2026 Joomill Extensions</copyright>
    <version>1.1.0</version>
    <namespace path="src">Joomill\Module\Contentcalendar</namespace>

    <!-- Scripts to run on installation -->
    <scriptfile>script.php</scriptfile>

    <!-- Files -->
    <files>
        <folder module="mod_contentcalendar">services</folder>
        <folder>language</folder>
        <folder>src</folder>
        <folder>tmpl</folder>
        <filename>mod_contentcalendar.xml</filename>
    </files>

    <!-- Media -->
    <media destination="mod_contentcalendar" folder="media">
        <folder>css</folder>
        <folder>js</folder>
    </media>

    <!-- Parameters -->
    <config>
        <fields
                name="params"
                addfieldprefix="Joomill\Module\Contentcalendar\Administrator\Field"
        >
            <fieldset name="basic">
                <field
                        name="categories"
                        type="category"
                        extension="com_content"
                        multiple="true"
                        label="MOD_CONTENTCALENDAR_CATEGORIES_LABEL"
                        description="MOD_CONTENTCALENDAR_CATEGORIES_DESCRIPTION"
                        default=""
                />
                <field
                        name=""
                        type="upgrade"
                />
            </fieldset>
            <fieldset name="display">
                <fieldset name="layout">
                    <field
                            name="layout"
                            type="pro"
                            label="JFIELD_ALT_LAYOUT_LABEL"
                            description="JFIELD_ALT_MODULE_LAYOUT_DESC"
                    />
                    <field
                            name="show_last_week"
                            type="pro"
                            label="MOD_CONTENTCALENDAR_SHOW_LAST_WEEK_LABEL"
                            description="MOD_CONTENTCALENDAR_SHOW_LAST_WEEK_DESC"
                    />
                    <field
                            name="weeks_count"
                            type="pro"
                            label="MOD_CONTENTCALENDAR_WEEKS_COUNT_LABEL"
                            description="MOD_CONTENTCALENDAR_WEEKS_COUNT_DESC"
                    />
                </fieldset>
                <fieldset name="colors">
                    <field
                            name="color_mode"
                            type="pro"
                            label="MOD_CONTENTCALENDAR_COLOR_MODE_LABEL"
                            description="MOD_CONTENTCALENDAR_COLOR_MODE_DESC"
                    />
                </fieldset>
            </fieldset>
            <fieldset name="article_defaults" label="MOD_CONTENTCALENDAR_FIELDSET_ARTICLE_DEFAULTS">
                <field
                        name="allow_add_articles"
                        type="pro"
                        label="MOD_CONTENTCALENDAR_ALLOW_ADD_ARTICLES_LABEL"
                        description="MOD_CONTENTCALENDAR_ALLOW_ADD_ARTICLES_DESC"
                />
                <field
                        name="default_publish_time"
                        type="pro"
                        label="MOD_CONTENTCALENDAR_DEFAULT_PUBLISH_TIME_LABEL"
                        description="MOD_CONTENTCALENDAR_DEFAULT_PUBLISH_TIME_DESC"
                />
                <field
                        name="default_category"
                        type="pro"
                        label="MOD_CONTENTCALENDAR_DEFAULT_CATEGORY_LABEL"
                        description="MOD_CONTENTCALENDAR_DEFAULT_CATEGORY_DESC"
                />
            </fieldset>
            <fieldset name="advanced">
                <field
                        name="moduleclass_sfx"
                        type="text"
                        label="COM_MODULES_FIELD_MODULECLASS_SFX_LABEL"
                        description="COM_MODULES_FIELD_MODULECLASS_SFX_DESC"
                />
                <field
                        name="header_icon"
                        type="text"
                        label="Header Icon"
                        default="fa-solid fa-calendar"
                />
                <field
                        type="editor"
                        name="custom_css"
                        label="MOD_CONTENTCALENDAR_CUSTOM_CSS_LABEL"
                        default=""
                        rows="10"
                        buttons="no"
                        editor="codemirror|none"
                        filter="raw"
                />

            </fieldset>
        </fields>
    </config>

    <!-- Help button URL -->
    <help key="" url="MOD_CONTENTCALENDAR_HELP_URL" />

    <!-- Changelog -->
    <changelogurl>
        <![CDATA[https://www.joomill-extensions.com/index.php?option=com_ochsubscriptions&amp;view=changelog&amp;format=xml&amp;cat=26]]></changelogurl>

    <!-- Updateserver -->
    <updateservers>
        <server type="extension" priority="1" name="Joomill Content Calendar FREE">
            <![CDATA[https://www.joomill-extensions.com/index.php?option=com_ochsubscriptions&amp;view=updater&amp;format=xml&amp;cat=26]]></server>
    </updateservers>
</extension>
